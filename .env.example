# =============================================================================
# ElyOS Core — Environment Variables / Környezeti változók
# =============================================================================
# Copy this file to .env and fill in the values.
# With Varlock + Infisical, only the bootstrap credentials below are required.
# All other variables are managed via Infisical and listed here for reference only.
# ---
# Másold ezt a fájlt .env névvel és töltsd ki az értékeket.
# Varlock + Infisical használatakor csak az alábbi bootstrap credentials szükséges.
# Az összes többi változó az Infisical-ban van kezelve, itt csak referencia céljából szerepelnek.
# =============================================================================

# -----------------------------------------------------------------------------
# Bootstrap Credentials [REQUIRED] / Bootstrap hitelesítő adatok [KÖTELEZŐ]
# -----------------------------------------------------------------------------
# These are the ONLY variables required in the .env file when using Varlock + Infisical.
# All other secrets are fetched from Infisical at runtime.
# ---
# Ezek az EGYETLEN változók, amelyek szükségesek a .env fájlban Varlock + Infisical használatakor.
# Az összes többi secret az Infisical-ból kerül lekérésre futásidőben.

INFISICAL_CLIENT_ID=your-machine-identity-client-id
INFISICAL_CLIENT_SECRET=your-machine-identity-client-secret

# =============================================================================
# Reference / Referencia — All other variables (managed via Infisical)
# Az összes többi változó (Infisical-ban kezelve)
# =============================================================================
# The variables below are NOT required in .env when using Varlock + Infisical.
# They are listed here for documentation purposes and for local fallback mode
# (VARLOCK_FALLBACK=local) when Infisical is not available (e.g. offline development).
# ---
# Az alábbi változók NEM szükségesek a .env fájlban Varlock + Infisical használatakor.
# Dokumentációs célból és lokális fallback módhoz (VARLOCK_FALLBACK=local) szerepelnek itt,
# amikor az Infisical nem elérhető (pl. offline fejlesztés).

# -----------------------------------------------------------------------------
# Server Configuration / Szerver konfiguráció
# -----------------------------------------------------------------------------

# Application environment. Values: development, production, test
# Az alkalmazás környezete. Értékek: development, production, test
# NODE_ENV=development

# Maximum request body size in bytes (default: 10MB)
# Maximális kérés törzs mérete bájtban (alapértelmezett: 10MB)
# BODY_SIZE_LIMIT=10485760

# Port for the ElyOS application (used by Docker). Default: 3000
# Az ElyOS alkalmazás portja (Docker által használt). Alapértelmezett: 3000
# ELYOS_PORT=3000

# Base URL of your ElyOS instance. Used for auth callbacks, email links, and CORS.
# Az ElyOS példány alap URL-je. Auth callback-ekhez, email linkekhez és CORS-hoz szükséges.
# APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Configuration / Adatbázis konfiguráció
# -----------------------------------------------------------------------------

# PostgreSQL connection URL. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# PostgreSQL kapcsolati URL. Formátum: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql://elyos:elyos123@localhost:5432/elyos

# Docker Compose deploy: use the postgres service name as host.
# Docker Compose deploy esetén: a postgres szolgáltatás nevét kell hostként megadni.
# DATABASE_URL=postgresql://elyos:elyos123@postgres:5432/elyos

# Individual PostgreSQL settings (used by Docker Compose)
# Egyedi PostgreSQL beállítások (Docker Compose használja)
# POSTGRES_USER=elyos
# POSTGRES_PASSWORD=elyos123
# POSTGRES_HOST=localhost
# POSTGRES_DB=elyos
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application Branding / Alkalmazás megjelenés
# -----------------------------------------------------------------------------

# Application display name
# Az alkalmazás megjelenített neve
# APP_NAME=ElyOS

# Logo URL — absolute (https://...) or relative (/logo-small.png)
# Logó URL — abszolút (https://...) vagy relatív (/logo-small.png)
# APP_LOGO_URL=/logos/logo-small.png

# Set to 'true' to use logo in emails instead of text.
# Állítsd 'true'-ra, ha emailekben logót szeretnél szöveg helyett.
# EMAIL_USE_LOGO=true

# -----------------------------------------------------------------------------
# Authentication / Hitelesítés (better-auth)
# -----------------------------------------------------------------------------

# Secret key for signing auth tokens. Generate with: openssl rand -base64 32
# Titkos kulcs az auth tokenek aláírásához. Generálás: openssl rand -base64 32
# BETTER_AUTH_SECRET=your-secret-here

# Base URL for auth callbacks. Must match APP_URL.
# Auth callback-ek alap URL-je. Egyeznie kell az APP_URL értékével.
# BETTER_AUTH_URL=http://localhost:3000

# Public URL of the app — required for SvelteKit adapter-node CSRF protection.
# Az alkalmazás publikus URL-je — a SvelteKit adapter-node CSRF védelméhez szükséges.
# ORIGIN=http://localhost:3000

# Allow new user registration.
# Új felhasználói regisztráció engedélyezése.
# REGISTRATION_ENABLED=true

# Enable Google/social login.
# Google/közösségi bejelentkezés engedélyezése.
# SOCIAL_LOGIN_ENABLED=true

# Google OAuth credentials (optional — only needed if using Google login)
# Google OAuth hitelesítő adatok (opcionális — csak Google bejelentkezéshez szükséges)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Initial Admin User / Kezdeti adminisztrátor felhasználó
# -----------------------------------------------------------------------------

# If set, db:init / db:reset will use this as the first admin user's email.
# Ha meg van adva, a db:init / db:reset során az első (rendszergazda) user email címét erre állítja.
# ADMIN_USER_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Initial Admin User / Kezdeti adminisztrátor felhasználó
# -----------------------------------------------------------------------------

# If set, db:init / db:reset will use this as the first admin user's email.
# Ha meg van adva, a db:init / db:reset során az első (rendszergazda) user email címét erre állítja.
# ADMIN_USER_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Email Configuration / Email konfiguráció
# -----------------------------------------------------------------------------

# Email provider to use. Values: smtp, resend, sendgrid, ses
# Használandó email szolgáltató. Értékek: smtp, resend, sendgrid, ses
# EMAIL_PROVIDER=smtp

# --- SMTP (Gmail, custom SMTP servers / egyedi SMTP szerverek) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USERNAME=your-username
# SMTP_PASSWORD=your-password
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=ElyOS
# SMTP_REPLY_TO=support@example.com

# --- Resend ---
# RESEND_API_KEY=re_your-api-key
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_VERIFIED_EMAIL=verified@yourdomain.com
# RESEND_WEBHOOK_SECRET=your-webhook-secret

# --- SendGrid ---
# SENDGRID_API_KEY=SG.your-api-key
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# --- AWS SES ---
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Email service settings / Email szolgáltatás beállítások
# EMAIL_TEST_MODE=false
# EMAIL_LOG_LEVEL=debug

# Email OTP expiration in minutes (1–20)
# Email OTP lejárati idő percben (1–20)
# EMAIL_OTP_EXPIRES_IN=10

# -----------------------------------------------------------------------------
# Email Verification / Email megerősítés
# -----------------------------------------------------------------------------

# Require email verification for new accounts.
# Email megerősítés megkövetelése új fiókoknál.
# REQUIRE_EMAIL_VERIFICATION=true

# Verification link expiration in seconds (default: 86400 = 24h, max: 604800 = 7d)
# Megerősítő link lejárati ideje másodpercben (alapértelmezett: 86400 = 24h, max: 604800 = 7d)
# EMAIL_VERIFICATION_EXPIRES_IN=86400

# Auto sign-in after email verification.
# Automatikus bejelentkezés email megerősítés után.
# AUTO_SIGNIN_AFTER_VERIFICATION=false

# Feature flags for email verification rollout.
# Feature flag-ek az email megerősítés fokozatos bevezetéséhez.
# VERIFICATION_FEATURE_ENABLED=true
# VERIFICATION_NEW_USERS_ONLY=false
# VERIFICATION_ROLLOUT_PERCENTAGE=100
# VERIFICATION_ROLLOUT_START_DATE=2024-01-01T00:00:00Z

# -----------------------------------------------------------------------------
# Internationalization / Többnyelvűség (i18n)
# -----------------------------------------------------------------------------

# Comma-separated list of supported locales.
# Támogatott nyelvek vesszővel elválasztva.
# SUPPORTED_LOCALES=hu,en

# Default locale (must be in SUPPORTED_LOCALES).
# Alapértelmezett nyelv (szerepelnie kell a SUPPORTED_LOCALES-ban).
# DEFAULT_LOCALE=hu

# -----------------------------------------------------------------------------
# Logging / Naplózás
# -----------------------------------------------------------------------------

# Active log targets (comma-separated): console, file, database
# Aktív napló célok (vesszővel elválasztva): console, file, database
# LOG_TARGETS=console

# Minimum log level: debug, info, warn, error, fatal
# Minimális napló szint: debug, info, warn, error, fatal
# LOG_LEVEL=debug

# Directory for log files (when LOG_TARGETS includes 'file').
# Naplófájlok könyvtára (ha a LOG_TARGETS tartalmazza a 'file' értéket).
# LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Development Mode / Fejlesztői mód
# -----------------------------------------------------------------------------

# Enable dev plugin loading from localhost.
# WARNING: Only enable in development environments!
# ---
# Fejlesztői plugin betöltés engedélyezése localhostról.
# FIGYELEM: Csak fejlesztői környezetben engedélyezd!
DEV_MODE=false

# -----------------------------------------------------------------------------
# Demo Mode / Demo mód
# -----------------------------------------------------------------------------

# Enable demo mode — the app indicates to users that they are in a demo environment.
# The actual database reset happens at infrastructure level: a separate Docker Compose
# configuration on the VPS resets the database to its initial state daily.
# This flag alone does not restrict data modifications.
# ---
# Demo mód engedélyezése — az alkalmazás jelzi a felhasználóknak, hogy demo környezetben futnak.
# A tényleges adatbázis-reset infrastruktúra szinten történik: a VPS-en egy külön
# Docker Compose konfiguráció naponta visszaállítja az adatbázist az alapállapotra.
# Ez a flag önmagában nem korlátozza az adatmódosításokat.
DEMO_MODE=false

# Hour (UTC, 0–23) when the demo database resets daily.
# Az óra (UTC, 0–23), amikor a demo adatbázis naponta visszaáll.
DEMO_RESET_HOUR=4

# Comma-separated uploads subdirectories to keep during demo reset.
# Vesszővel elválasztott feltöltési alkönyvtárak, amelyek megmaradnak a demo reset során.
DEMO_RESET_UPLOADS_KEEP=backgrounds/shared

# -----------------------------------------------------------------------------
# Public Site / Publikus oldal
# -----------------------------------------------------------------------------

# Set to 'false' to disable the public-facing site and redirect to /admin.
# Állítsd 'false'-ra a publikus oldal letiltásához és /admin-ra való átirányításhoz.
# PUBLIC_SITE_ENABLED=true

# -----------------------------------------------------------------------------
# Plugin System / Plugin rendszer
# -----------------------------------------------------------------------------

# Plugin package file extension (without dot).
# Plugin csomag fájlkiterjesztés (pont nélkül).
# PLUGIN_PACKAGE_EXTENSION=elyospkg

# Maximum plugin package size in bytes (default: 10MB, max: 100MB)
# Maximális plugin csomag mérete bájtban (alapértelmezett: 10MB, max: 100MB)
# PLUGIN_MAX_SIZE=10485760

# Directory for installed plugin storage.
# Telepített pluginok tárolási könyvtára.
# PLUGIN_STORAGE_DIR=/var/webos/plugins

# Temporary directory for plugin uploads/extraction.
# Ideiglenes könyvtár plugin feltöltéshez/kicsomagoláshoz.
# PLUGIN_TEMP_DIR=/tmp/webos-plugins
