# =============================================================================
# ElyOS Core — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Application environment [REQUIRED]
# Values: development, production, test
NODE_ENV=development

# Maximum request body size in bytes (default: 10MB)
BODY_SIZE_LIMIT=10485760

# Port for the ElyOS application (used by Docker)
# Default: 3000
ELYOS_PORT=3000

# Base URL of your ElyOS instance [REQUIRED in production]
# Used for auth callbacks, email links, and CORS
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL connection URL [REQUIRED]
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://elyos:elyos123@localhost:5432/elyos

# Individual PostgreSQL settings (used by Docker Compose)
POSTGRES_USER=elyos
POSTGRES_PASSWORD=elyos123
POSTGRES_DB=elyos
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application Branding
# -----------------------------------------------------------------------------

# Application display name
APP_NAME=ElyOS

# Logo URL — absolute (https://...) or relative (/logo-small.png)
APP_LOGO_URL=/logos/logo-small.png

# Set to 'true' to use logo in emails instead of text
EMAIL_USE_LOGO=true

# -----------------------------------------------------------------------------
# Authentication (better-auth)
# -----------------------------------------------------------------------------

# Secret key for signing auth tokens [REQUIRED in production]
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Base URL for auth callbacks [REQUIRED]
# Must match APP_URL
BETTER_AUTH_URL=http://localhost:3000
# Az alkalmazás publikus URL-je — a SvelteKit adapter-node CSRF védelméhez szükséges.
# Production-ban állítsd be a valós domain-re (pl. https://elyos.example.com).
# Ha nincs beállítva, a remote function hívások 403-as hibával meghiúsulnak.
ORIGIN=http://localhost:3000

# Allow new user registration
REGISTRATION_ENABLED=true

# Enable Google/social login
SOCIAL_LOGIN_ENABLED=true

# Google OAuth credentials (optional — only if using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------

# Email provider to use
# Values: smtp, resend, sendgrid, ses
EMAIL_PROVIDER=smtp

# --- SMTP (Gmail, custom SMTP servers) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-username
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=ElyOS
SMTP_REPLY_TO=support@example.com

# --- Resend ---
# RESEND_API_KEY=re_your-api-key
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_VERIFIED_EMAIL=verified@yourdomain.com
# RESEND_WEBHOOK_SECRET=your-webhook-secret

# --- SendGrid ---
# SENDGRID_API_KEY=SG.your-api-key
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# --- AWS SES ---
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Email service settings
EMAIL_TEST_MODE=false
EMAIL_LOG_LEVEL=debug

# Email OTP expiration in minutes (1–20)
EMAIL_OTP_EXPIRES_IN=10

# -----------------------------------------------------------------------------
# Email Verification
# -----------------------------------------------------------------------------

# Require email verification for new accounts
REQUIRE_EMAIL_VERIFICATION=true

# Verification link expiration in seconds (default: 86400 = 24h, max: 604800 = 7d)
EMAIL_VERIFICATION_EXPIRES_IN=86400

# Auto sign-in after email verification
AUTO_SIGNIN_AFTER_VERIFICATION=false

# Feature flags for email verification rollout
VERIFICATION_FEATURE_ENABLED=true
VERIFICATION_NEW_USERS_ONLY=false
VERIFICATION_ROLLOUT_PERCENTAGE=100
# VERIFICATION_ROLLOUT_START_DATE=2024-01-01T00:00:00Z

# -----------------------------------------------------------------------------
# Internationalization (i18n)
# -----------------------------------------------------------------------------

# Comma-separated list of supported locales
SUPPORTED_LOCALES=hu,en

# Default locale (must be in SUPPORTED_LOCALES)
DEFAULT_LOCALE=hu

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Active log targets (comma-separated: console, file, database)
LOG_TARGETS=console

# Minimum log level: debug, info, warn, error, fatal
LOG_LEVEL=debug

# Directory for log files (when LOG_TARGETS includes 'file')
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Development Mode
# -----------------------------------------------------------------------------

# Enable dev plugin loading from localhost
# WARNING: Only enable in development environments!
DEV_MODE=false

# -----------------------------------------------------------------------------
# Demo Mode
# -----------------------------------------------------------------------------

# Enable demo mode (read-only, no real data changes)
DEMO_MODE=false

# Hour (UTC, 0–23) when the demo database resets daily
DEMO_RESET_HOUR=4

# Comma-separated uploads subdirectories to keep during demo reset
# DEMO_RESET_UPLOADS_KEEP=avatars,thumbnails

# -----------------------------------------------------------------------------
# Public Site
# -----------------------------------------------------------------------------

# Set to 'false' to disable the public-facing site and redirect to /admin
PUBLIC_SITE_ENABLED=true

# -----------------------------------------------------------------------------
# Plugin System
# -----------------------------------------------------------------------------

# Plugin package file extension (without dot)
PLUGIN_PACKAGE_EXTENSION=elyospkg

# Maximum plugin package size in bytes (default: 10MB, max: 100MB)
PLUGIN_MAX_SIZE=10485760

# Directory for installed plugin storage
PLUGIN_STORAGE_DIR=/var/webos/plugins

# Temporary directory for plugin uploads/extraction
PLUGIN_TEMP_DIR=/tmp/webos-plugins
